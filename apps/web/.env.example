NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-only (waitlist route). Never expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Auth entry: defaults to /login in dev, /waitlist in production builds.
# NEXT_PUBLIC_AUTH_ENTRY=login
# NEXT_PUBLIC_AUTH_ENTRY=waitlist

# Supabase dashboard setup:
# - Enable Google and Azure providers.
# - Enable email/password confirmations.
# - Configure Brevo as Supabase Auth custom SMTP (host, port, login, password, sender).

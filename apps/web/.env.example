NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Public API URL (browser SSE + fallback). Production: https://YOUR-SERVICE.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-only API URL for BFF routes (/api/waitlist, /api/backend, etc.).
# On Vercel production, set this to your Render URL (recommended over localhost).
# API_URL=https://YOUR-SERVICE.onrender.com

# Auth entry: defaults to /login in dev + localhost, /waitlist in production builds.
# NEXT_PUBLIC_AUTH_ENTRY=login
# NEXT_PUBLIC_AUTH_ENTRY=waitlist

# Pre-launch: production exposes only marketing pages + waitlist (see public-site-gate.ts).
# Set to true when the product is ready for public sign-in and app access.
# NEXT_PUBLIC_APP_ENABLED=true
# Force gate on preview/staging: NEXT_PUBLIC_PRELAUNCH_MODE=true

# Optional fallback for server-side auth redirects when Origin header is missing.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase dashboard setup:
# - Enable Google and Azure providers.
# - Enable email/password confirmations.
# - Configure Brevo as Supabase Auth custom SMTP (host, port, login, password, sender).
#
# Service-role credentials live only in services/api/.env (never in the web app).
# Must match services/api INTERNAL_PROXY_SECRET in production (required in prod).
# Generate with: openssl rand -base64 32
INTERNAL_PROXY_SECRET=

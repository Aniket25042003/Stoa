  "batch_generation_script": "# From repo root with GEMINI_API_KEY set:\nfor f in apps/web/public/images/marketing/specs/orb-faces/0*.json apps/web/public/images/marketing/specs/orb-faces/orb-fallback.json; do\n  out=$(jq -r '.marketing_image.meta.output_path' \"$f\" | sed 's|public/|apps/web/public/|')\n  python3 ~/.cursor/skills/nano-banana-pro/generate_image.py \\\n    \"$(jq -r .render_prompt \"$f\")\" \\\n    -o \"$out\" --aspect-ratio 1:1 --size 2K\ndone"

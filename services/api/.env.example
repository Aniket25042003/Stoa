SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret from Supabase Settings > API > JWT Secret (HS256)
SUPABASE_JWT_SECRET=

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# LangSmith (optional) — official env names (recommended on workers)
# https://docs.langchain.com/oss/python/langgraph/observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=gtm-agent

# Legacy LangChain tracing (optional) — mapped to LANGSMITH_* when unset
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=gtm-agent

# Optional research keys (see gtm_agents/tools/research.py)
GTM_DISABLE_EXTERNAL_RESEARCH=false

# ──────────────────────────── LLM provider ────────────────────────────
# Primary LLM provider used for autonomous MCP tool selection and open-ended
# GTM synthesis. Switch this manually to force the other provider; the app
# only auto-failovers when the *primary is down* (raises an error).
#   vertex  → Google Vertex AI (Gemini) — recommended primary
#   openai  → OpenAI Chat Completions (used as fallback by default)
GTM_LLM_PROVIDER=vertex
# When true (default), exceptions from the primary trigger one auto attempt
# on the other provider. Set to false to disable failover entirely.
GTM_LLM_AUTO_FAILOVER=true
GTM_LLM_TEMPERATURE=0.25
GTM_LLM_TIMEOUT_SECONDS=60

# Vertex AI (primary). Auth resolves via google-auth ADC:
#   - set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON file, OR
#   - run `gcloud auth application-default login` for local dev.
GTM_VERTEX_MODEL=gemini-2.5-pro
GTM_VERTEX_MODEL_FAST=gemini-2.5-flash
GTM_VERTEX_MODEL_PRO=gemini-2.5-pro
GTM_VERTEX_PROJECT=
GTM_VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# OpenAI (fallback). OPENAI_API_KEY is read from the standard env var.
GTM_OPENAI_MODEL=gpt-4o-mini
GTM_OPENAI_MODEL_FAST=gpt-4o-mini
GTM_OPENAI_MODEL_PRO=gpt-4o
OPENAI_API_KEY=

# Legacy OpenAI model env vars — still honored as aliases for GTM_OPENAI_MODEL
# when set, so existing deployments keep working without edits.
GTM_AGENT_MODEL=
GTM_SYNTHESIS_MODEL=

GTM_RESEARCH_MCP_SERVER=
TAVILY_API_KEY=
JINA_API_KEY=
SERPAPI_API_KEY=

# Crawlee + Playwright crawler (worker). Install browsers: `playwright install chromium --with-deps`
GTM_CRAWLER_USER_AGENT=gtm-agent-crawler/0.1 (+https://example.com)
GTM_CRAWLER_MAX_PAGES=25
GTM_CRAWLER_MAX_DEPTH=2
GTM_CRAWLER_MIN_CONCURRENCY=1
GTM_CRAWLER_MAX_CONCURRENCY=4
GTM_CRAWLER_REQUEST_TIMEOUT_SECS=45
GTM_CRAWLER_HTTP_FALLBACK_TIMEOUT_SECS=10
GTM_CRAWLER_HTTP_FALLBACK_MAX_PAGES=3
GTM_CRAWLER_RESPECT_ROBOTS=true
CRAWLEE_STORAGE_DIR=/tmp/crawlee

# Research orchestration budgets
GTM_RESEARCH_MAX_SECONDS=240
GTM_RESEARCH_MAX_TOOL_CALLS=8
GTM_RESEARCH_MIN_SOURCES_FOR_APPROVAL=12

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret from Supabase Settings > API > JWT Secret (HS256)
SUPABASE_JWT_SECRET=

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=gtm-agent

# Optional research keys (see gtm_agents/tools/research.py)
GTM_DISABLE_EXTERNAL_RESEARCH=false
# LLM used for autonomous MCP tool selection and open-ended GTM synthesis.
GTM_AGENT_MODEL=
GTM_SYNTHESIS_MODEL=
GTM_RESEARCH_MCP_SERVER=
TAVILY_API_KEY=
JINA_API_KEY=
SERPAPI_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=gtm-agent/0.1
X_API_BEARER_TOKEN=

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

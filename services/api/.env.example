SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
REDIS_URL=redis://:localdev@localhost:6379/0
CELERY_BROKER_URL=redis://:localdev@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:localdev@localhost:6379/1
STOA_ENV=development
# Production: use rediss:// with password (Render Key Value provides this). TLS required by default in prod.
REDIS_REQUIRE_TLS=false
REDIS_SSL_VERIFY=true
CORS_ORIGINS=http://localhost:3000
APP_BASE_URL=http://localhost:3000
INVITE_TOKEN_PEPPER=change-me-in-production
STOA_LLM_PROVIDER=vertex
STOA_LLM_AUTO_FAILOVER=true
GTM_VERTEX_PROJECT=
GTM_VERTEX_LOCATION=us-central1
GTM_VERTEX_MODEL=gemini-2.5-pro
GTM_VERTEX_MODEL_FAST=gemini-2.5-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=stoa-intelligence

# Knowledge base / RAG
EMBED_MODEL=gemini-embedding-001
EMBED_DIMENSIONS=3072
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5
RETRIEVAL_CANDIDATE_K=40
RETRIEVAL_FINAL_K=12
RETRIEVAL_TOKEN_BUDGET=2000
KB_CACHE_TTL_SECONDS=3600

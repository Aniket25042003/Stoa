{
  "name": "gtm-agent-monorepo",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "lint:web": "pnpm --filter web lint",
    "dev:api": "cd services/api && .venv/bin/uvicorn app.main:app --reload --port 8000",
    "dev:worker": "bash services/api/scripts/dev_worker.sh"
  }
}
